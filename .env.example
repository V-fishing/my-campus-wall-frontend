# ============================================================
# Campus Wall 前端 —— 本地开发环境配置模板
#
# 用法（B 机）：复制为 .env.local（已被 .gitignore 的 *.local 忽略，不会提交）
#   cp .env.example .env.local
# 然后把地址改成「后端所在那台 B 机」的局域网 IP。
#
#   · H5 浏览器预览        → 可用 http://localhost:8080（前后端同机时）
#   · 微信开发者工具/真机   → 必须用后端 B 机的局域网 IP，如 http://172.21.160.221:8080
#       （微信真机访问 localhost 会失败；用 `ip addr` / `hostname -I` 查 IP）
#
# .env.local 在 Vite 所有模式都会加载（dev:mp-weixin / dev:h5 / build 均生效）。
# ============================================================

VITE_API_BASE_URL=http://172.21.160.221:8080
VITE_WS_BASE_URL=ws://172.21.160.221:8080
