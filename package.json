    "build:mp-alipay": "npm run prepare-config && uni build -p mp-alipay",
    "build:mp-baidu": "npm run prepare-config && uni build -p mp-baidu",
    "build:mp-jd": "npm run prepare-config && uni build -p mp-jd",
