    "dev:mp-lark": "npm run prepare-config && uni -p mp-lark",
    "dev:mp-qq": "npm run prepare-config && uni -p mp-qq",
    "dev:mp-toutiao": "npm run prepare-config && uni -p mp-toutiao",
    "dev:mp-harmony": "npm run prepare-config && uni -p mp-harmony",
